# Copy this file to .env and fill in the values

# Database
DATABASE_USER=valadir_user
DATABASE_PASSWORD=valadir_password

# Redis
REDIS_PASSWORD=valadir_redis_password

# JWT
# EC P-256 private key in JWK format (public key is derived from it). Used to sign authentication tokens
JWT_PRIVATE_KEY={"kty":"EC","crv":"P-256","x":"...","y":"...","d":"..."}
